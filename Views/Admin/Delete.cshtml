@model NewsletterAppCore.Models.NewsletterSignUp

<div class="container mt-5">

    <div class="card shadow-sm col-lg-6 mx-auto">
        <div class="card-header bg-danger text-white">
            <h4 class="m-0">Confirm Delete</h4>
        </div>

        <div class="card-body">

            <p class="lead">
                Are you sure you want to delete this subscriber?
            </p>

            <dl class="row">
                <dt class="col-sm-4">First Name</dt>
                <dd class="col-sm-8">@Model.FirstName</dd>

                <dt class="col-sm-4">Last Name</dt>
                <dd class="col-sm-8">@Model.LastName</dd>

                <dt class="col-sm-4">Email</dt>
                <dd class="col-sm-8">@Model.EmailAddress</dd>
            </dl>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />

                <button type="submit" class="btn btn-danger">
                    Yes, Delete
                </button>

                <a asp-action="Index" class="btn btn-secondary ms-2">
                    Cancel
                </a>
            </form>

        </div>
    </div>

</div>