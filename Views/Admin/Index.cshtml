@model IEnumerable<NewsletterAppCore.Models.ViewModels.SignUpVm>

<!--
    Admin Dashboard - Newsletter Signups
    This page lists all newsletter subscribers and provides CRUD actions.
    Following MVC conventions: Views/Admin/Index.cshtml matches AdminController.Index()
-->

<div class="container mt-4">

    <!-- Page Title -->
    <h2 class="mb-4">Newsletter Signups</h2>

    <!-- Empty State -->
    @if (!Model.Any())
    {
        <div class="alert alert-info shadow-sm">
            No signups found.
        </div>
    }
    else
    {
        <!--
            Responsive, polished Bootstrap table.
            table-hover + shadow-sm improves readability and visual polish.
            Right-aligned action buttons follow common admin UI patterns.
        -->
        <table class="table table-striped table-hover shadow-sm">
            <thead class="table-dark">
                <tr>
                    <th>First Name</th>
                    <th>Last Name</th>
                    <th>Email</th>

                    <!--
                        Fixed width column for action buttons.
                        Prevents layout shifting and keeps UI consistent.
                    -->
                    <th class="text-end" style="width: 240px;">Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <!-- Display subscriber info -->
                        <td>@item.FirstName</td>
                        <td>@item.LastName</td>
                        <td>@item.EmailAddress</td>

                        <td class="text-end">

                            <!-- Details Button -->
                            <a asp-action="Details"
                               asp-route-id="@item.Id"
                               class="btn btn-info btn-sm me-1">
                                Details
                            </a>

                            <!-- Edit Button -->
                            <a asp-action="Edit"
                               asp-route-id="@item.Id"
                               class="btn btn-warning btn-sm me-1">
                                Edit
                            </a>

                            <!--
                                Delete Button (POST)
                                - Uses POST for safety (best practice)
                                - Includes confirmation dialog
                                - Anti-forgery token included automatically
                            -->
                            <form asp-controller="Admin"
                                  asp-action="Delete"
                                  asp-route-id="@item.Id"
                                  method="post"
                                  class="d-inline">

                                <button type="submit"
                                        class="btn btn-danger btn-sm"
                                        onclick="return confirm('Are you sure you want to delete this record?');">
                                    Delete
                                </button>

                            </form>


                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>